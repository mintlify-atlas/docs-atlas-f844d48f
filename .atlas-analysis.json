  "keyFeatures": [
    "Profile picture tracking and history with automatic detection",
    "Username change monitoring and timeline",
    "Server icon tracking with historical archive",
    "Comprehensive statistics with change frequency analysis",
    "Automatic periodic updates every 30 minutes",
    "Docker deployment with persistent storage",
    "SQLite database with migration support",
    "ImgBB integration for reliable image hosting"
  ],
  "publicApiSurface": [
    "/monitor - Start tracking a user's profile picture and username",
    "/removemonitor - Stop tracking a user",
    "/pfphistory - View a user's profile picture history",
    "/usernamehistory - View a user's username history",
    "/stats - Show statistics about a user's profile picture changes",
    "/monitorserver - Start tracking server icon changes",
    "/removemonitorserver - Stop tracking server icon changes",
    "/serverpfphistory - View server icon history",
    "/serverstats - Show statistics about server icon changes",
    "/ping - Check bot status"
  ]
